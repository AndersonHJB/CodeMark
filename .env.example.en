# CodeMark environment example.
# Copy this file to .env for local development, or to .env.prod for production.
# Values with spaces are quoted so the file can also be loaded by shell scripts.

# Django settings module.
# Local development: codemark_project.settings.dev
# Production: codemark_project.settings.prod
DJANGO_SETTINGS_MODULE=codemark_project.settings.dev

# Django secret key. Use a unique, unpredictable value in production.
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# Debug switch. Use 1 to enable and 0 to disable.
# Production should use 0.
DJANGO_DEBUG=1

# Comma-separated hostnames/IPs accepted by Django.
# Examples: 127.0.0.1,localhost or example.com,www.example.com,127.0.0.1,localhost
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Optional SQLite database path.
# Leave commented to use the default project-root db.sqlite3.
# DJANGO_SQLITE_PATH=/absolute/path/to/db.sqlite3

# Maximum request body size accepted by Django, in bytes.
# Default here is 50 MiB.
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=52428800

# Root logger level. Common values: DEBUG, INFO, WARNING, ERROR.
DJANGO_LOG_LEVEL=INFO

# Registration and verification email backend.
# Console backend prints email content to the server console, useful for local development.
# SMTP backend sends real email.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Default sender shown in outgoing emails.
DJANGO_DEFAULT_FROM_EMAIL="CodeMark <no-reply@example.com>"

# SMTP server settings.
# For SSL port 465 use DJANGO_EMAIL_USE_SSL=1 and DJANGO_EMAIL_USE_TLS=0.
# For STARTTLS port 587 use DJANGO_EMAIL_USE_SSL=0 and DJANGO_EMAIL_USE_TLS=1.
DJANGO_EMAIL_HOST=smtp.exmail.qq.com
DJANGO_EMAIL_PORT=465
DJANGO_EMAIL_USE_SSL=1
DJANGO_EMAIL_USE_TLS=0
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=

# SMTP network timeout in seconds.
DJANGO_EMAIL_TIMEOUT=10

# C++ online editor runtime.
# Leave CODEMARK_CPP_COMPILER empty to search PATH for g++ first, then clang++.
CODEMARK_CPP_COMPILER=

# C++ compile timeout, in seconds.
CPP_EDITOR_COMPILE_TIMEOUT_SECONDS=12

# C++ non-interactive run timeout, in seconds.
CPP_EDITOR_RUN_TIMEOUT_SECONDS=3

# C++ interactive run timeout, in seconds.
CPP_EDITOR_INTERACTIVE_RUN_TIMEOUT_SECONDS=60

# Maximum submitted C++ source/project file size, in bytes.
CPP_EDITOR_MAX_CODE_BYTES=102400

# Maximum stdin accepted for C++ runs, in bytes.
CPP_EDITOR_MAX_STDIN_BYTES=32768

# Maximum stdout/stderr captured for C++ runs, in bytes.
CPP_EDITOR_MAX_OUTPUT_BYTES=65536

# Admin bootstrap command defaults for:
# python manage.py create_admin_account
CODEMARK_ADMIN_USERNAME=admin
CODEMARK_ADMIN_EMAIL=
CODEMARK_ADMIN_PASSWORD=

# Deployment helper virtualenv directory for scripts/init_deploy.sh.
# This is read from the parent shell before the script sources .env.prod.
# Export it before running the script when using a non-default virtualenv path.
CODEMARK_VENV_DIR=.venv
