# CodeMark 环境变量示例。
# 本地开发可复制为 .env，生产部署可复制为 .env.prod。
# 包含空格的值已使用引号，便于同时被 python-dotenv 和 shell 脚本读取。

# Django 配置模块。
# 本地开发：codemark_project.settings.dev
# 生产环境：codemark_project.settings.prod
DJANGO_SETTINGS_MODULE=codemark_project.settings.dev

# Django 密钥。生产环境必须使用唯一且不可预测的值。
# 生成方式：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# 调试开关。1 表示开启，0 表示关闭。
# 生产环境应设置为 0。
DJANGO_DEBUG=1

# Django 允许访问的域名或 IP，多个值用英文逗号分隔。
# 示例：127.0.0.1,localhost 或 example.com,www.example.com,127.0.0.1,localhost
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# 可选 SQLite 数据库路径。
# 保持注释时使用项目根目录下的 db.sqlite3。
# DJANGO_SQLITE_PATH=/absolute/path/to/db.sqlite3

# Django 接收请求体的最大大小，单位为字节。
# 这里默认是 50 MiB。
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=52428800

# 根日志级别。常用值：DEBUG、INFO、WARNING、ERROR。
DJANGO_LOG_LEVEL=INFO

# 注册验证码邮件后端。
# console 后端会把邮件内容打印到服务端控制台，适合本地开发。
# SMTP 后端会发送真实邮件。
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# 对外发送邮件时显示的默认发件人。
DJANGO_DEFAULT_FROM_EMAIL="CodeMark <no-reply@example.com>"

# SMTP 服务器配置。
# SSL 端口 465 通常使用 DJANGO_EMAIL_USE_SSL=1 且 DJANGO_EMAIL_USE_TLS=0。
# STARTTLS 端口 587 通常使用 DJANGO_EMAIL_USE_SSL=0 且 DJANGO_EMAIL_USE_TLS=1。
DJANGO_EMAIL_HOST=smtp.exmail.qq.com
DJANGO_EMAIL_PORT=465
DJANGO_EMAIL_USE_SSL=1
DJANGO_EMAIL_USE_TLS=0
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=

# SMTP 网络超时时间，单位为秒。
DJANGO_EMAIL_TIMEOUT=10

# C++ 在线编辑器运行环境。
# CODEMARK_CPP_COMPILER 留空时，会先从 PATH 查找 g++，再查找 clang++。
CODEMARK_CPP_COMPILER=

# C++ 编译超时时间，单位为秒。
CPP_EDITOR_COMPILE_TIMEOUT_SECONDS=12

# C++ 非交互式运行超时时间，单位为秒。
CPP_EDITOR_RUN_TIMEOUT_SECONDS=3

# C++ 交互式运行超时时间，单位为秒。
CPP_EDITOR_INTERACTIVE_RUN_TIMEOUT_SECONDS=60

# C++ 提交源码或项目文件的最大大小，单位为字节。
CPP_EDITOR_MAX_CODE_BYTES=102400

# C++ 运行时允许的最大 stdin 输入，单位为字节。
CPP_EDITOR_MAX_STDIN_BYTES=32768

# C++ 运行时捕获 stdout/stderr 的最大大小，单位为字节。
CPP_EDITOR_MAX_OUTPUT_BYTES=65536

# 管理员初始化命令的默认参数：
# python manage.py create_admin_account
CODEMARK_ADMIN_USERNAME=admin
CODEMARK_ADMIN_EMAIL=
CODEMARK_ADMIN_PASSWORD=

# 部署初始化脚本 scripts/init_deploy.sh 使用的虚拟环境目录。
# 该变量会在脚本 source .env.prod 之前从父 shell 中读取。
# 如果虚拟环境不在默认路径，请在运行脚本前先 export 该变量。
CODEMARK_VENV_DIR=.venv
